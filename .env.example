# Proton Mail Bridge credentials
# Use the Bridge-generated password — NOT your ProtonMail login password.
# Find it in the Proton Bridge desktop app under Account > Mailbox password.
PROTONMAIL_BRIDGE_HOST=127.0.0.1
PROTONMAIL_BRIDGE_IMAP_PORT=1143
PROTONMAIL_BRIDGE_USERNAME=your@protonmail.com
PROTONMAIL_BRIDGE_PASSWORD=bridge-generated-password-here

# IMAP connection pool
PROTONMAIL_CONNECTION_POOL_MIN=1
PROTONMAIL_CONNECTION_POOL_MAX=5
PROTONMAIL_CONNECTION_POOL_IDLE_DRAIN_SECS=30    # drain to min after N idle seconds
PROTONMAIL_CONNECTION_POOL_IDLE_TIMEOUT_SECS=300 # empty pool after N idle seconds (0 = disabled)

# MCP HTTP server
PROTONMAIL_MCP_HOST=127.0.0.1
PROTONMAIL_MCP_PORT=3000
PROTONMAIL_MCP_BASE_PATH=/mcp
PROTONMAIL_MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# Operation log (revert_operations tool)
PROTONMAIL_OPERATION_LOG_SIZE=100     # max entries in revert log ring buffer

# Logging
PROTONMAIL_AUDIT_LOG_PATH=./audit.jsonl
PROTONMAIL_LOG_PATH=                 # leave empty to write to stderr
PROTONMAIL_LOG_LEVEL=info            # trace | debug | info | warn | error
