{
  "name": "proton-bridge-mcp",
  "version": "0.2.0",
  "description": "MCP server bridging ProtonMail via Proton Bridge IMAP",
  "type": "module",
  "main": "./dist/index.js",
  "author": "Michael Fröhlich",
  "license": "MIT",
  "homepage": "https://github.com/grover/proton-bridge-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grover/proton-bridge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/grover/proton-bridge-mcp/issues"
  },
  "keywords": ["protonmail", "proton-mail", "imap", "email", "mcp", "bridge", "claude", "anthropic"],
  "engines": {
    "node": ">=25.9.0"
  },
  "bin": {
    "proton-bridge-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "assets/icon-16.png",
    "assets/icon-32.png",
    "assets/icon-64.png",
    "assets/icon-256.png",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "inspector": "npm run build && bash scripts/run_inspector.sh",
    "smoketest": "npm run build && bash scripts/run_smoketest.sh",
    "package": "npm run build && bash scripts/build-mcpb.sh",
    "release": "git checkout main && git pull origin main && npx release-it"
  },
  "volta": {
    "node": "25.9.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^13.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "imapflow": "^1.0.0",
    "mailparser": "^3.0.0",
    "pino": "^9.0.0",
    "selfsigned": "^2.4.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "latest",
    "@release-it/bumper": "^6.0.1",
    "@release-it/keep-a-changelog": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mailparser": "^3.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.3.0",
    "release-it": "^17.0.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
